# ─── Gmail contact form ──────────────────────────────────────────────────────
#
# GMAIL_USER = your Gmail address (e.g. clevisgikenyi@gmail.com)
# GMAIL_APP_PASSWORD = a 16-character App Password from Google
#
# How to get your App Password (takes 2 minutes):
#   1. Go to myaccount.google.com/security
#   2. Make sure 2-Step Verification is ON (required)
#   3. Search "App passwords" or go to myaccount.google.com/apppasswords
#   4. Select app: "Mail", device: "Other" → type "Portfolio"
#   5. Google gives you a 16-char password like: abcd efgh ijkl mnop
#   6. Paste it below WITHOUT spaces: abcdefghijklmnop
#
GMAIL_USER=clevisgikenyi@gmail.com
GMAIL_APP_PASSWORD=ctrb fxja yfrm kxjm

# ─── Anthropic API (AI quote assistant) ──────────────────────────────────────
# Get your key at console.anthropic.com once your account is open
ANTHROPIC_API_KEY=sk-ant-your_key_here
